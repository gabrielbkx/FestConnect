<?xml version='1.0' encoding='UTF-8' standalone="no"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet author="GF" id="0.1.1-260326_1935">
        <addColumn tableName="tb_prestador">
            <column name="cep" type="VARCHAR(8)" />
            <column name="logradouro" type="VARCHAR(100)" />
            <column name="numero" type="VARCHAR(10)" />
            <column name="complemento" type="VARCHAR(100)" />
            <column name="bairro" type="VARCHAR(100)" />
            <column name="cidade" type="VARCHAR(100)" />
            <column name="estado" type="VARCHAR(50)" />
        </addColumn>

    </changeSet>

    <changeSet author="GF" id="0.1.1-260326_1952">

        <dropColumn tableName="tb_prestador" columnName="telefone" />

        <addNotNullConstraint tableName="tb_prestador"
                              columnName="whatsapp"
                              columnDataType="VARCHAR(255)" />

    </changeSet>

    <changeSet author="GF" id="0.1.1-260326_2017">

        <createTable tableName="tb_item_catalogo">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="titulo" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="descricao" type="TEXT"/>
            <column name="preco_base" type="DECIMAL(10, 2)"/>

            <column name="tipo" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="ativo" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>

            <column name="prestador_id" type="UUID">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseColumnNames="prestador_id"
                                 baseTableName="tb_item_catalogo"
                                 constraintName="fk_item_catalogo_prestador"
                                 referencedColumnNames="id"
                                 referencedTableName="tb_prestador"/>

        <addColumn tableName="tb_midia">
            <column name="item_catalogo_id" type="UUID">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <addForeignKeyConstraint baseColumnNames="item_catalogo_id"
                                 baseTableName="tb_midia"
                                 constraintName="fk_midia_item_catalogo"
                                 referencedColumnNames="id"
                                 referencedTableName="tb_item_catalogo"/>

    </changeSet>

    <changeSet author="GF" id="0.1.1-260326_2144">
        <dropColumn tableName="tb_prestador" columnName="raio_atendimento_km"/>
    </changeSet>

    <changeSet author="GF" id="0.1.1-260326_2249">
        <dropNotNullConstraint tableName="tb_item_catalogo"
                               columnName="preco_base"
                               columnDataType="decimal(19,2)"/>
    </changeSet>
</databaseChangeLog>